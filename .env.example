# === Sekoia.io HTTP Intake ===
SEKOIA_INTAKE_KEY=your-intake-key-here
SEKOIA_INTAKE_URL=https://intake.sekoia.io/plain

# === IP Enrichment — ipinfo.io (optionnel) ===
# Sans token : 50 000 req/mois gratuit. Avec token : jusqu'à 150 000/mois (plan free).
# Créer un token sur https://ipinfo.io/signup
IPINFO_TOKEN=

# === Azure / Entra ID (optionnel) ===
# Créer un Service Principal avec le rôle Reader sur les souscriptions
# et les permissions Graph Application.Read.All + Domain.Read.All.
# Voir README.md > "Collecteur Azure / Entra ID" pour la procédure complète.
# "Directory (tenant) ID" dans Azure AD
AZURE_TENANT_ID=   
# "Application (client) ID" de l'App Registration
AZURE_CLIENT_ID=
# Secret généré via "az ad app credential reset"
AZURE_CLIENT_SECRET=

# === Comportement ===
DRY_RUN=false
LOG_LEVEL=INFO
