# === Sekoia.io HTTP Intake ===
SEKOIA_INTAKE_KEY=your-intake-key-here
SEKOIA_INTAKE_URL=https://intake.sekoia.io/plain

# === Azure / Entra ID (optionnel) ===
# Créer un Service Principal avec le rôle Reader sur les souscriptions
# et les permissions Graph Application.Read.All + Domain.Read.All.
# Voir README.md > "Collecteur Azure / Entra ID" pour la procédure complète.
AZURE_TENANT_ID=          # "Directory (tenant) ID" dans Azure AD
AZURE_CLIENT_ID=          # "Application (client) ID" de l'App Registration
AZURE_CLIENT_SECRET=      # Secret généré via "az ad app credential reset"

# === Comportement ===
DRY_RUN=false
LOG_LEVEL=INFO
